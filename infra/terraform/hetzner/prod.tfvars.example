# Prod environment — copy to prod.tfvars and fill in values.
# Sensitive vars (tokens) are read from .env via TF_VAR_ environment variables.

env          = "prod"
location     = "ash"
network_zone = "us-east"

ssh_key_name       = ""
tailscale_tailnet  = ""
git_repo_url       = "https://github.com/username/k8s-platform.git"

# Server sizing
cp_server_type     = "cpx21"
worker_server_type = "cpx21"
nat_gateway_type   = "cpx11"
load_balancer_type = "lb11"

# Component versions
kubernetes_version     = "v1.32.13"
cilium_version         = "1.19.2"
argocd_version         = "9.4.17"
sealed_secrets_version = "2.18.4"
ccm_version            = "1.30.1"
csi_version            = "2.20.0"
