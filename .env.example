# HETZNER CLOUD
HCLOUD_TOKEN=
HCLOUD_TOKEN_READONLY=
HETZNER_SSH_KEY_NAME=

# TAILSCALE
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=

# GCP
# Per-env SA keys at keys/gcp-tfstate-{env}.json and keys/gcp-backup-{env}.json
GCS_TFSTATE_BUCKET_DEV=
GCS_TFSTATE_BUCKET_PROD=
GCS_BACKUP_BUCKET_DEV=
GCS_BACKUP_BUCKET_PROD=

# GIT
GIT_REPO_URL=https://github.com/username/hetzner-k8s-platform.git

# MISC
# Run 'task cluster:set-email' after setting this to template it into ClusterIssuers
LETS_ENCRYPT_EMAIL=admin@example.com
DOMAIN=example.com
