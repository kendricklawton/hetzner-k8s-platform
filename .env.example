# Copy to .env and fill in values. Never commit .env.
# Non-sensitive Terraform vars live in infra/terraform/hetzner/{dev,prod}.tfvars
# GCS SA key files (gitignored): keys/gcp-tfstate-{dev,prod}.json

# =============================================================================
# TERRAFORM SECRETS — auto-read by Terraform via TF_VAR_ prefix
# =============================================================================
TF_VAR_token=
TF_VAR_token_readonly=
TF_VAR_tailscale_api_key=

# =============================================================================
# PACKER SECRET — auto-read by Packer via PKR_VAR_ prefix
# =============================================================================
PKR_VAR_hcloud_token=

# =============================================================================
# GCS — state backend and etcd backup buckets (used by Taskfile, not TF vars)
# =============================================================================
HETZNER_TFSTATE_BUCKET_DEV=
HETZNER_TFSTATE_BUCKET_PROD=
HETZNER_BACKUP_BUCKET_DEV=
HETZNER_BACKUP_BUCKET_PROD=

# =============================================================================
# PLATFORM — used by Taskfile helpers (set-repo, set-email)
# =============================================================================
GIT_REPO_URL=https://github.com/username/k8s-platform.git
LETS_ENCRYPT_EMAIL=admin@example.com
DOMAIN=example.com
