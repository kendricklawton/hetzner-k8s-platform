# ===========================================================================
# HETZNER CLOUD
# ===========================================================================
HCLOUD_TOKEN=
HCLOUD_TOKEN_READONLY=
HETZNER_SSH_KEY_NAME=

# ===========================================================================
# TAILSCALE
# ===========================================================================
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=

# ===========================================================================
# GCP (Terraform state backend + backup buckets)
# ===========================================================================
GCP_PROJECT_ID=
GCP_REGION=us-central1

# GCS bucket names for backup tasks
GCS_SEALED_SECRETS_BUCKET=
GCS_ETCD_BUCKET=

# ===========================================================================
# GIT
# ===========================================================================
GIT_REPO_URL=https://github.com/username/hetzner-k8s-platform.git

# ===========================================================================
# MISC
# ===========================================================================
# Run 'task cluster:set-email' after setting this to template it into ClusterIssuers
LETS_ENCRYPT_EMAIL=admin@example.com
