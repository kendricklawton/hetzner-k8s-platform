# Copy to .env and fill in values. Never commit .env.
# GCS SA key files (gitignored): keys/gcp-tfstate-{dev,prod}.json

# =============================================================================
# HETZNER — compute credentials, Tailscale, and state/backup
# State and backups use GCS (Hetzner has no native object storage)
# =============================================================================
HCLOUD_TOKEN=
HCLOUD_TOKEN_READONLY=
HETZNER_SSH_KEY_NAME=

TAILSCALE_API_KEY=
TAILSCALE_TAILNET=

HETZNER_TFSTATE_BUCKET_DEV=
HETZNER_TFSTATE_BUCKET_PROD=
HETZNER_BACKUP_BUCKET_DEV=
HETZNER_BACKUP_BUCKET_PROD=

# =============================================================================
# PLATFORM
# =============================================================================
GIT_REPO_URL=https://github.com/username/k8s-platform.git
LETS_ENCRYPT_EMAIL=admin@example.com
DOMAIN=example.com
